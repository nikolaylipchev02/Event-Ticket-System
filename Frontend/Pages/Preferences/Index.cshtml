@page
@model Frontend.Pages.Preferences.IndexModel
@{
    ViewData["Title"] = "Preferences";
}

<section class="surface-card">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end mb-4">
        <div>
            <span class="eyebrow">Preference service</span>
            <h1 class="h2 mt-2 mb-2">User preference</h1>
            <p class="page-copy mb-0">Loads the signed-in user's preference record from the JWT-backed endpoint.</p>
        </div>
        <a class="btn btn-outline-light px-4" asp-page="/Index">Back to dashboard</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.LoadError)) {
        <div class="alert alert-warning" role="alert">@Model.LoadError</div>
    }
    else if (Model.Preference is null) {
        <p class="muted mb-0">No preference record exists for the signed-in user yet.</p>
    }
    else {
        <p class="mb-0">Preference loaded for <code>@Model.Preference.UserId</code>.</p>
    }
</section>
