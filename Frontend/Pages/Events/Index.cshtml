@page
@model Frontend.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
}

<section class="surface-card">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end mb-4">
        <div>
            <span class="eyebrow">Event service</span>
            <h1 class="h2 mt-2 mb-2">Event catalog</h1>
            <p class="page-copy mb-0">
                This page is wired to <code>GET api/events</code> and now creates events with the full
                <code>POST api/events</code> payload: title, description, city, category, price, date, and total
                tickets.
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-primary px-4" data-bs-toggle="modal"
                    data-bs-target="#createEventModal">
                Create Event
            </button>
            <a class="btn btn-outline-light px-4" asp-page="/Index">Back to dashboard</a>
        </div>
    </div>

    <div class="info-card p-4 mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-2 align-items-lg-center mb-3">
            <div>
                <span class="section-title">Filter events</span>
                <p class="muted mb-0">Search by city, category, price, or date range using the backend filter API.</p>
            </div>
            @if (Model.HasActiveFilters) {
                <a class="btn btn-outline-light btn-sm px-3" asp-page="/Events/Index">Clear filters</a>
            }
        </div>

        <form method="get" class="row g-3">
            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label" for="filterCity">City</label>
                <select id="filterCity" asp-for="FilterCity" asp-items="Model.CityOptions" class="form-select">
                    <option value="">All cities</option>
                </select>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label" for="filterCategory">Category</label>
                <select id="filterCategory" asp-for="FilterCategory" asp-items="Model.CategoryOptions"
                        class="form-select">
                    <option value="">All categories</option>
                </select>
            </div>
            <div class="col-6 col-lg-2">
                <label class="form-label" for="filterMinPrice">Min price</label>
                <input id="filterMinPrice" asp-for="FilterMinPrice" class="form-control" type="number" min="0"
                       step="0.01" inputmode="decimal" placeholder="0.00"/>
            </div>
            <div class="col-6 col-lg-2">
                <label class="form-label" for="filterMaxPrice">Max price</label>
                <input id="filterMaxPrice" asp-for="FilterMaxPrice" class="form-control" type="number" min="0"
                       step="0.01" inputmode="decimal" placeholder="100.00"/>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label" for="filterFromDate">From date</label>
                <input id="filterFromDate" asp-for="FilterFromDate" class="form-control" type="datetime-local"
                       asp-format="{0:yyyy-MM-ddTHH:mm}"/>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label" for="filterToDate">To date</label>
                <input id="filterToDate" asp-for="FilterToDate" class="form-control" type="datetime-local"
                       asp-format="{0:yyyy-MM-ddTHH:mm}"/>
            </div>
            <div class="col-12 col-lg-2 d-grid">
                <button type="submit" class="btn btn-primary">Apply filters</button>
            </div>
        </form>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage)) {
        <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.LoadError)) {
        <div class="alert alert-warning" role="alert">@Model.LoadError</div>
    }

    @if (Model.Events.Count == 0) {
        <p class="muted mb-0">No events were returned yet.</p>
    }
    else {
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                <tr>
                    <th>Event</th>
                    <th>Schedule</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
            @foreach (EventItem eventItem in Model.Events) {
                <tr>
                    <td>
                        <strong class="d-block">@eventItem.Title</strong>
                            <div class="d-flex flex-wrap gap-2 mt-2">
                                <span class="event-chip">@Model.FormatEnumValue(eventItem.City.ToString())</span>
                                <span class="event-chip">@Model.FormatEnumValue(eventItem.Category.ToString())</span>
                                <span class="event-chip">@eventItem.Price.ToString("0.00")</span>
                                <span class="event-chip">Tickets: @eventItem.TotalTickets</span>
                            </div>
                            <div class="muted small mt-2">@eventItem.Description</div>
                        </td>
                        <td>
                            <div class="fw-semibold">@eventItem.Date.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                            <div class="muted small">Event date and start time</div>
                        </td>
                        <td>@eventItem.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                        <td class="text-end">
                            <div class="d-inline-flex flex-wrap gap-2 justify-content-end">
                                <form method="post" asp-page-handler="Book" class="d-inline">
                                    <input type="hidden" name="BookEventId" value="@eventItem.Id"/>
                                    <input type="hidden" name="BookIdempotencyKey"
                                           value="@Guid.NewGuid()"/>
                                    <button type="submit" class="btn btn-sm btn-primary">Book</button>
                                </form>
                                <button type="button"
                                        class="btn btn-sm btn-outline-light"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editEventModal"
                                        data-event-id="@eventItem.Id"
                                        data-event-title="@eventItem.Title"
                                        data-event-description="@eventItem.Description"
                                        data-event-city="@eventItem.City"
                                        data-event-category="@eventItem.Category"
                                        data-event-price="@eventItem.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                        data-event-date="@eventItem.Date.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")">
                                    Update
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-info"
                                        data-copy-event-id="@eventItem.Id">
                                    Copy
                                </button>
                                <form method="post" asp-page-handler="Delete" class="d-inline"
                                      onsubmit="return confirm('Delete this event?');">
                                    <input type="hidden" name="DeleteId" value="@eventItem.Id"/>
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <div class="modal fade" id="createEventModal" tabindex="-1" aria-labelledby="createEventModalLabel"
         aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content modal-surface">
                <div class="modal-header">
                    <div>
                        <span class="eyebrow">Event service</span>
                        <h2 class="modal-title h4 mt-1 mb-0" id="createEventModalLabel">Create Event</h2>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(Model.FormError)) {
                        <div class="alert alert-warning" role="alert">@Model.FormError</div>
                    }

                    <form method="post" class="row g-4" id="createEventForm">
                        <div class="col-12">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label" for="title">Title</label>
                                    <input id="title" asp-for="Title" class="form-control"
                                           placeholder="Summer concert night"/>
                                    <span class="text-danger small" asp-validation-for="Title"></span>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="description">Description</label>
                                    <textarea id="description" asp-for="Description" class="form-control" rows="4"
                                              placeholder="Write a short description for the event"></textarea>
                                    <span class="text-danger small" asp-validation-for="Description"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="city">City</label>
                                    <select id="city" asp-for="City" asp-items="Model.CityOptions" class="form-select">
                                        <option value="">Choose a city</option>
                                    </select>
                                    <span class="text-danger small" asp-validation-for="City"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="category">Category</label>
                                    <select id="category" asp-for="Category" asp-items="Model.CategoryOptions" class="form-select">
                                        <option value="">Choose a category</option>
                                    </select>
                                    <span class="text-danger small" asp-validation-for="Category"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="price">Price</label>
                                    <input id="price" asp-for="Price" class="form-control" type="number" min="0"
                                           step="0.01" inputmode="decimal" placeholder="25.00"/>
                                    <span class="text-danger small" asp-validation-for="Price"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="date">Date</label>
                                    <input id="date" asp-for="Date" class="form-control" type="datetime-local"
                                           asp-format="{0:yyyy-MM-ddTHH:mm}"/>
                                    <span class="text-danger small" asp-validation-for="Date"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="totalTickets">Tickets available</label>
                                    <div class="counter-shell">
                                        <button type="button" class="counter-step-button" data-ticket-step="-1"
                                                aria-label="Decrease tickets available">
                                            -
                                        </button>
                                        <input id="totalTickets" asp-for="TotalTickets" class="form-control counter-value"
                                               type="number" min="1" step="1" inputmode="numeric"
                                               placeholder="250"/>
                                        <button type="button" class="counter-step-button" data-ticket-step="1"
                                                aria-label="Increase tickets available">
                                            +
                                        </button>
                                    </div>
                                    <span class="text-danger small" asp-validation-for="TotalTickets"></span>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary px-4" type="submit" form="createEventForm">Create event</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editEventModal" tabindex="-1" aria-labelledby="editEventModalLabel" aria-hidden="true"
         data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content modal-surface">
                <div class="modal-header">
                    <div>
                        <span class="eyebrow">Event service</span>
                        <h2 class="modal-title h4 mt-1 mb-0" id="editEventModalLabel">Update Event</h2>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(Model.FormError) && Model.ShowEditModal) {
                        <div class="alert alert-warning" role="alert">@Model.FormError</div>
                    }

                    <p class="page-copy mb-3">Change any event field you want. Leave a field blank if you do not want
                        to change it.</p>

                    <form method="post" asp-page-handler="Update" class="row g-3" id="updateEventForm">
                        <input type="hidden" asp-for="UpdateId" id="updateEventId"/>
                        <div class="col-12">
                            <label class="form-label" for="updateTitle">Title</label>
                            <input id="updateTitle" asp-for="UpdateTitle" class="form-control"
                                   placeholder="Summer concert night"/>
                            <span class="text-danger small" asp-validation-for="UpdateTitle"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="updateDescription">Description</label>
                            <textarea id="updateDescription" asp-for="UpdateDescription" class="form-control" rows="4"
                                      placeholder="Write a short description for the event"></textarea>
                            <span class="text-danger small" asp-validation-for="UpdateDescription"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="updateCity">City</label>
                            <select id="updateCity" asp-for="UpdateCity" asp-items="Model.CityOptions"
                                    class="form-select">
                                <option value="">Keep current city</option>
                            </select>
                            <span class="text-danger small" asp-validation-for="UpdateCity"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="updateCategory">Category</label>
                            <select id="updateCategory" asp-for="UpdateCategory" asp-items="Model.CategoryOptions"
                                    class="form-select">
                                <option value="">Keep current category</option>
                            </select>
                            <span class="text-danger small" asp-validation-for="UpdateCategory"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="updatePrice">Price</label>
                            <input id="updatePrice" asp-for="UpdatePrice" class="form-control" type="number" min="0"
                                   step="0.01" inputmode="decimal" placeholder="25.00"/>
                            <span class="text-danger small" asp-validation-for="UpdatePrice"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="updateDate">Date</label>
                            <input id="updateDate" asp-for="UpdateDate" class="form-control" type="datetime-local"
                                   asp-format="{0:yyyy-MM-ddTHH:mm}"/>
                            <span class="text-danger small" asp-validation-for="UpdateDate"></span>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary px-4" type="submit" form="updateEventForm">Save changes</button>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    @if (Model.ShowCreateModal) {
        <script>
            window.addEventListener('load', function () {
                const modalElement = document.getElementById('createEventModal');
                if (modalElement) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            });
        </script>
    }
    @if (Model.ShowEditModal) {
        <script>
            window.addEventListener('load', function () {
                const modalElement = document.getElementById('editEventModal');
                if (modalElement) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            });
        </script>
    }
    <script>
        window.addEventListener('DOMContentLoaded', function () {
            const totalTicketsField = document.getElementById('totalTickets');
            const counterButtons = document.querySelectorAll('[data-ticket-step]');

            if (totalTicketsField instanceof HTMLInputElement) {
                if (!totalTicketsField.value) {
                    totalTicketsField.value = '1';
                }

                totalTicketsField.addEventListener('blur', function () {
                    const parsedValue = parseInt(totalTicketsField.value || '0', 10);
                    if (Number.isNaN(parsedValue) || parsedValue < 1) {
                        totalTicketsField.value = '1';
                    }
                });
            }

            counterButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    if (!(totalTicketsField instanceof HTMLInputElement)) {
                        return;
                    }

                    const currentValue = parseInt(totalTicketsField.value || '0', 10) || 0;
                    const step = parseInt(button.getAttribute('data-ticket-step') || '0', 10) || 0;
                    const nextValue = Math.max(1, currentValue + step);
                    totalTicketsField.value = String(nextValue);
                    totalTicketsField.focus();
                });
            });

            const editModal = document.getElementById('editEventModal');
            if (!editModal) {
                return;
            }

            editModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                if (!button) {
                    return;
                }

                const id = button.getAttribute('data-event-id') || '';
                const title = button.getAttribute('data-event-title') || '';
                const description = button.getAttribute('data-event-description') || '';
                const city = button.getAttribute('data-event-city') || '';
                const category = button.getAttribute('data-event-category') || '';
                const price = button.getAttribute('data-event-price') || '';
                const date = button.getAttribute('data-event-date') || '';

                const idField = document.getElementById('updateEventId');
                const titleField = document.getElementById('updateTitle');
                const descriptionField = document.getElementById('updateDescription');
                const cityField = document.getElementById('updateCity');
                const categoryField = document.getElementById('updateCategory');
                const priceField = document.getElementById('updatePrice');
                const dateField = document.getElementById('updateDate');

                if (idField) {
                    idField.value = id;
                }

                if (titleField) {
                    titleField.value = title;
                }

                if (descriptionField) {
                    descriptionField.value = description;
                }

                if (cityField) {
                    cityField.value = city;
                }

                if (categoryField) {
                    categoryField.value = category;
                }

                if (priceField) {
                    priceField.value = price;
                }

                if (dateField) {
                    dateField.value = date;
                }
            });
        });
    </script>
}
