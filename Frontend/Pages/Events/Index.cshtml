@page
@model Frontend.Pages.Events.IndexModel
@{
    ViewData["Title"] = "Events";
}

<section class="surface-card">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end mb-4">
        <div>
            <span class="eyebrow">Event service</span>
            <h1 class="h2 mt-2 mb-2">Event catalog</h1>
            <p class="page-copy mb-0">
                This page is wired to <code>GET api/events</code> and now creates events with the full
                <code>POST api/events</code> payload: title, description, city, category, price, and date.
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-primary px-4" data-bs-toggle="modal"
                    data-bs-target="#createEventModal">
                Create Event
            </button>
            <a class="btn btn-outline-light px-4" asp-page="/Index">Back to dashboard</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage)) {
        <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.LoadError)) {
        <div class="alert alert-warning" role="alert">@Model.LoadError</div>
    }

    @if (Model.Events.Count == 0) {
        <p class="muted mb-0">No events were returned yet.</p>
    }
    else {
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                <tr>
                    <th>Event</th>
                    <th>Schedule</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (EventItem eventItem in Model.Events) {
                    <tr>
                        <td>
                            <strong class="d-block">@eventItem.Title</strong>
                            <div class="d-flex flex-wrap gap-2 mt-2">
                                <span class="event-chip">@Model.FormatEnumValue(eventItem.City.ToString())</span>
                                <span class="event-chip">@Model.FormatEnumValue(eventItem.Category.ToString())</span>
                                <span class="event-chip">@eventItem.Price.ToString("0.00")</span>
                            </div>
                            <div class="muted small mt-2">@eventItem.Description</div>
                        </td>
                        <td>
                            <div class="fw-semibold">@eventItem.Date.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                            <div class="muted small">Event date and start time</div>
                        </td>
                        <td>@eventItem.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                        <td class="text-end">
                            <div class="d-inline-flex flex-wrap gap-2 justify-content-end">
                                <button type="button"
                                        class="btn btn-sm btn-outline-light"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editEventModal"
                                        data-event-id="@eventItem.Id"
                                        data-event-title="@eventItem.Title"
                                        data-event-description="@eventItem.Description">
                                    Update
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-info"
                                        data-copy-event-id="@eventItem.Id">
                                    Copy
                                </button>
                                <form method="post" asp-page-handler="Delete" class="d-inline"
                                      onsubmit="return confirm('Delete this event?');">
                                    <input type="hidden" name="DeleteId" value="@eventItem.Id"/>
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <div class="modal fade" id="createEventModal" tabindex="-1" aria-labelledby="createEventModalLabel"
         aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content modal-surface">
                <div class="modal-header">
                    <div>
                        <span class="eyebrow">Event service</span>
                        <h2 class="modal-title h4 mt-1 mb-0" id="createEventModalLabel">Create Event</h2>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(Model.FormError)) {
                        <div class="alert alert-warning" role="alert">@Model.FormError</div>
                    }

                    <form method="post" class="row g-4" id="createEventForm">
                        <div class="col-12">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label" for="title">Title</label>
                                    <input id="title" asp-for="Title" class="form-control"
                                           placeholder="Summer concert night"/>
                                    <span class="text-danger small" asp-validation-for="Title"></span>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="description">Description</label>
                                    <textarea id="description" asp-for="Description" class="form-control" rows="4"
                                              placeholder="Write a short description for the event"></textarea>
                                    <span class="text-danger small" asp-validation-for="Description"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="city">City</label>
                                    <select id="city" asp-for="City" asp-items="Model.CityOptions" class="form-select">
                                        <option value="">Choose a city</option>
                                    </select>
                                    <span class="text-danger small" asp-validation-for="City"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="category">Category</label>
                                    <select id="category" asp-for="Category" asp-items="Model.CategoryOptions" class="form-select">
                                        <option value="">Choose a category</option>
                                    </select>
                                    <span class="text-danger small" asp-validation-for="Category"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="price">Price</label>
                                    <input id="price" asp-for="Price" class="form-control" type="number" min="0"
                                           step="0.01" inputmode="decimal" placeholder="25.00"/>
                                    <span class="text-danger small" asp-validation-for="Price"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" for="date">Date</label>
                                    <input id="date" asp-for="Date" class="form-control" type="datetime-local"
                                           asp-format="{0:yyyy-MM-ddTHH:mm}"/>
                                    <span class="text-danger small" asp-validation-for="Date"></span>
                                </div>
                            </div>
                        </div>

                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary px-4" type="submit" form="createEventForm">Create event</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editEventModal" tabindex="-1" aria-labelledby="editEventModalLabel" aria-hidden="true"
         data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content modal-surface">
                <div class="modal-header">
                    <div>
                        <span class="eyebrow">Event service</span>
                        <h2 class="modal-title h4 mt-1 mb-0" id="editEventModalLabel">Update Event</h2>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrWhiteSpace(Model.FormError) && Model.ShowEditModal) {
                        <div class="alert alert-warning" role="alert">@Model.FormError</div>
                    }

                    <p class="page-copy mb-3">Change the title, the description, or both. Leave a field blank if you do
                        not want to change it.</p>

                    <form method="post" asp-page-handler="Update" class="row g-3" id="updateEventForm">
                        <input type="hidden" asp-for="UpdateId" id="updateEventId"/>
                        <div class="col-12">
                            <label class="form-label" for="updateTitle">Title</label>
                            <input id="updateTitle" asp-for="UpdateTitle" class="form-control"
                                   placeholder="Summer concert night"/>
                            <span class="text-danger small" asp-validation-for="UpdateTitle"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="updateDescription">Description</label>
                            <textarea id="updateDescription" asp-for="UpdateDescription" class="form-control" rows="4"
                                      placeholder="Write a short description for the event"></textarea>
                            <span class="text-danger small" asp-validation-for="UpdateDescription"></span>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary px-4" type="submit" form="updateEventForm">Save changes</button>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    @if (Model.ShowCreateModal) {
        <script>
            window.addEventListener('load', function () {
                const modalElement = document.getElementById('createEventModal');
                if (modalElement) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            });
        </script>
    }
    @if (Model.ShowEditModal) {
        <script>
            window.addEventListener('load', function () {
                const modalElement = document.getElementById('editEventModal');
                if (modalElement) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            });
        </script>
    }
    <script>
        window.addEventListener('DOMContentLoaded', function () {
            const editModal = document.getElementById('editEventModal');
            if (!editModal) {
                return;
            }

            editModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                if (!button) {
                    return;
                }

                const id = button.getAttribute('data-event-id') || '';
                const title = button.getAttribute('data-event-title') || '';
                const description = button.getAttribute('data-event-description') || '';

                const idField = document.getElementById('updateEventId');
                const titleField = document.getElementById('updateTitle');
                const descriptionField = document.getElementById('updateDescription');

                if (idField) {
                    idField.value = id;
                }

                if (titleField) {
                    titleField.value = title;
                }

                if (descriptionField) {
                    descriptionField.value = description;
                }
            });
        });
    </script>
}
