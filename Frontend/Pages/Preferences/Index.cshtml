@page
@model Frontend.Pages.Preferences.IndexModel
@{
    ViewData["Title"] = "Preferences";
}

<section class="surface-card">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end mb-4">
        <div>
            <span class="eyebrow">Preference service</span>
            <h1 class="h2 mt-2 mb-2">User preference</h1>
            <p class="page-copy mb-0">Enter a user ID to load or update the preference record.</p>
        </div>
        <a class="btn btn-outline-light px-4" asp-page="/Index">Back to dashboard</a>
    </div>

    <form method="get" class="row g-3 mb-4">
        <div class="col-12 col-lg-8">
            <label class="form-label" for="userId">User ID</label>
            <input id="userId" name="UserId" value="@Model.UserId" class="form-control" placeholder="00000000-0000-0000-0000-000000000000" />
        </div>
        <div class="col-12 col-lg-4 d-flex align-items-end">
            <button class="btn btn-primary w-100" type="submit">Load preference</button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.LoadError))
    {
        <div class="alert alert-warning" role="alert">@Model.LoadError</div>
    }
    else if (Model.UserId is null)
    {
        <p class="muted mb-0">Preferences will appear after you submit a user ID.</p>
    }
    else if (Model.Preference is null)
    {
        <p class="muted mb-0">No preference record exists for this user yet.</p>
    }
    else
    {
        <p class="mb-0">Preference loaded for <code>@Model.Preference.UserId</code>.</p>
    }
</section>
